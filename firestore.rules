rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 0. Global Safety Net
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    // Admin lookup - assuming an 'admins' collection exists with UID as doc ID
    // Also including owner email as a hardcoded admin for ease of setup
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "brijdhararealtech@gmail.com"
      );
    }

    // ---------------------------------------------------------
    // Enquiry Validation
    // ---------------------------------------------------------
    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'project', 'createdAt'])
        && data.name is string && data.name.size() >= 2
        && data.email is string
        && data.phone is string
        && data.project is string
        && data.createdAt is timestamp;
    }

    // ---------------------------------------------------------
    // Subscriber Validation
    // ---------------------------------------------------------
    function isValidSubscriber(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.email is string
        && data.createdAt is timestamp;
    }

    // ---------------------------------------------------------
    // User Validation
    // ---------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'photoURL', 'createdAt'])
        && data.displayName is string
        && data.email is string
        && data.photoURL is string
        && data.createdAt is timestamp;
    }

    // ---------------------------------------------------------
    // Booking Validation
    // ---------------------------------------------------------
    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'userName', 'userEmail', 'projectName', 'date', 'time', 'status', 'createdAt'])
        && data.userId == request.auth.uid
        && data.userName is string
        && data.userEmail is string
        && data.projectName is string
        && data.date is string
        && data.time is string
        && data.status in ['pending', 'confirmed', 'declined', 'completed', 'cancelled']
        && data.createdAt is timestamp;
    }

    // ---------------------------------------------------------
    // Collection Match Blocks
    // ---------------------------------------------------------
    
    // Enquiries: Anyone can submit, only admins can view
    match /enquiries/{enquiryId} {
      allow create: if isValidEnquiry(incoming());
      allow get, list, update, delete: if isAdmin();
    }

    // Subscribers: Anyone can submit, only admins can view
    match /subscribers/{subscriberId} {
      allow create: if isValidSubscriber(incoming());
      allow get, list, update, delete: if isAdmin();
    }

    // Users: Users can manage their own profile
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId 
        && isValidUser(incoming()) 
        && incoming().email == existing().email 
        && incoming().createdAt == existing().createdAt;
      allow list, delete: if isAdmin();
    }

    // Bookings: Users can create and view their own bookings
    match /bookings/{bookingId} {
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming());
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        && (incoming().status == 'confirmed' || incoming().status == 'declined' || incoming().status == 'pending');
      allow delete: if isAdmin();
    }

    // Admin collection: No one can modify except manually in console
    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if false;
    }
  }
}
