rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 0. Global Safety Net
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    // Admin lookup - assuming an 'admins' collection exists with UID as doc ID
    // Also including owner email as a hardcoded admin for ease of setup
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "brijdhararealtech@gmail.com" ||
        request.auth.token.email == "brijvaasrealtech@gmail.com" ||
        request.auth.token.email == "brijdhara@gmai.com" ||
        request.auth.token.email == "brijdhara@gmail.com"
      );
    }

    // ---------------------------------------------------------
    // Enquiry Validation
    // ---------------------------------------------------------
    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'project', 'createdAt'])
        && data.name is string && data.name.size() >= 2
        && data.email is string
        && data.phone is string
        && data.project is string
        && data.createdAt is timestamp;
    }

    // ---------------------------------------------------------
    // Subscriber Validation
    // ---------------------------------------------------------
    function isValidSubscriber(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.email is string
        && data.createdAt is timestamp;
    }

    // ---------------------------------------------------------
    // User Validation
    // ---------------------------------------------------------
    function isValidUser(data) {
      return data.get('displayName', 'Anonymous') is string
        && data.get('email', '') is string
        && data.get('createdAt', request.time) is timestamp;
    }

    // ---------------------------------------------------------
    // Booking Validation
    // ---------------------------------------------------------
    function isValidBooking(data) {
      return data.userId == request.auth.uid
        && data.get('userName', 'Anonymous') is string
        && data.get('projectName', 'General') is string
        && data.get('createdAt', request.time) is timestamp;
    }

    // ---------------------------------------------------------
    // Collection Match Blocks
    // ---------------------------------------------------------
    
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow get, list, update, delete: if isSignedIn();
    }

    match /subscribers/{subscriberId} {
      allow create: if true;
      allow get, list, update, delete: if isSignedIn();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow list, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if isSignedIn();
      allow get, list: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Admin collection: No one can modify except manually in console
    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if false;
    }
  }
}
