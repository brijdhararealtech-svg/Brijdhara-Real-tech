rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 0. Global Safety Net
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Primitives & Helpers
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() in [
          "brijdhararealtech@gmail.com",
          "brijvaasrealtech@gmail.com",
          "brijdhara@gmail.com"
        ] ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // Validation Blueprints
    // ---------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'userName', 'userEmail', 'projectName', 'date', 'time', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.userEmail is string && data.userEmail.size() <= 100 &&
             data.projectName is string &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
             data.createdAt == request.time;
    }

    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'project', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.project is string &&
             data.createdAt == request.time;
    }

    // ---------------------------------------------------------
    // Collection Match Blocks
    // ---------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidBooking(incoming()) && incoming().status == 'pending';
      
      allow update: if isSignedIn() && (
        // Admin can update anything
        isAdmin() ||
        // User can only update if they own it AND only specific fields (like cancel)
        (isOwner(existing().userId) && 
         isValidBooking(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
         incoming().status == 'cancelled')
      );
      
      allow delete: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      allow create: if isValidEnquiry(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /subscribers/{subscriberId} {
      allow create: if incoming().keys().hasAll(['email', 'createdAt']) && incoming().email is string;
      allow read, update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
    }
  }
}
